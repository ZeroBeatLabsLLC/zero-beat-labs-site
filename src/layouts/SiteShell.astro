---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  activePage?: 'home' | 'services' | 'writing';
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  structuredData?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  activePage,
  ogType = 'website',
  ogImage = '/og.png',
  ogImageAlt = title,
  structuredData,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(ogImage, Astro.site);

const navItems = [
  { label: 'Home', href: '/#home', page: 'home' },
  { label: 'Services', href: '/services/', page: 'services' },
  { label: 'How we work', href: '/#process' },
  { label: 'Proof', href: '/#proof' },
  { label: 'Writing', href: '/writing/', page: 'writing' },
  { label: 'Contact', href: '/#contact' },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    {!noindex && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1B2A6B" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="ZeroBeatLabs Writing" href="/rss.xml" />
    {!noindex && <meta property="og:type" content={ogType} />}
    {!noindex && <meta property="og:title" content={title} />}
    {!noindex && <meta property="og:description" content={description} />}
    {!noindex && <meta property="og:url" content={canonical} />}
    {!noindex && <meta property="og:site_name" content="ZeroBeatLabs" />}
    {!noindex && <meta property="og:image" content={socialImage} />}
    {!noindex && <meta property="og:image:width" content="1200" />}
    {!noindex && <meta property="og:image:height" content="630" />}
    {!noindex && <meta property="og:image:alt" content={ogImageAlt} />}
    {!noindex && <meta name="twitter:card" content="summary_large_image" />}
    {structuredData && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="site-name" href="/#home" aria-label="ZeroBeatLabs home">
          <img class="site-logo" src="/logo.png" width="1800" height="400" alt="ZeroBeatLabs" />
        </a>

        <nav class="desktop-nav" aria-label="Main navigation">
          <ul>
            {navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={'page' in item && item.page === activePage ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <nav class="mobile-nav" aria-label="Mobile navigation">
          <ul>
            {navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={'page' in item && item.page === activePage ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-grid">
        <div>
          <a class="footer-brand" href="/#home">ZeroBeatLabs</a>
          <p>Governed workflow automation for IT and operations.</p>
        </div>
        <div>
          <p>
            &copy; {new Date().getFullYear()} ZeroBeatLabs LLC &middot; a service by
            <a href="https://samjolley.com">Sam Jolley</a>
          </p>
          <p>
            <a href="tel:+18102304295">(810) 230-4295</a> &middot;
            <a href="mailto:hello@zerobeatlabs.org">hello@zerobeatlabs.org</a> &middot;
            <a href="/privacy/">Privacy</a>
          </p>
        </div>
        <div>
          <p>
            Local Web is an endorsed service line at
            <a href="https://web.zerobeatlabs.org">web.zerobeatlabs.org</a>.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
