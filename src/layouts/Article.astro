---
import SiteShell from './SiteShell.astro';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  structuredData?: object;
}

const { title, description, ogType = 'website', structuredData } = Astro.props;
const activePage = Astro.url.pathname.startsWith('/writing') ? 'writing' : undefined;
---

<SiteShell
  title={title}
  description={description}
  ogType={ogType}
  structuredData={structuredData}
  activePage={activePage}
>
  <div class="wrap article-shell">
    <slot />
  </div>
</SiteShell>
