---
import '../styles/global.css';

const title = 'Page not found | ZeroBeatLabs';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap">
        <a class="site-name" href="/">ZeroBeatLabs</a>
      </div>
    </header>
    <main id="main">
      <section aria-labelledby="notfound-heading">
        <div class="wrap">
          <h1 id="notfound-heading">Page not found</h1>
          <p class="lede">The page you requested does not exist or has moved.</p>
          <p>
            <a class="button" href="/">Return to the home page</a>
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
