---
import SiteShell from '../layouts/SiteShell.astro';

const title = 'Page not found | ZeroBeatLabs';
---

<SiteShell
  title={title}
  description="The requested ZeroBeatLabs page does not exist or has moved."
  noindex={true}
>
  <section aria-labelledby="notfound-heading">
    <div class="wrap narrow">
      <p class="eyebrow">404</p>
      <h1 id="notfound-heading">Page not found</h1>
      <p class="lede">The page you requested does not exist or has moved.</p>
      <p><a class="button" href="/">Return to the home page</a></p>
    </div>
  </section>
</SiteShell>
