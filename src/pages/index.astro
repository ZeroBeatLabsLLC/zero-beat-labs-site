---
import '../styles/global.css';

const title = 'ZeroBeatLabs | Turn recurring IT exports into a report your stakeholders can use';
const description =
  'ZeroBeatLabs builds fixed-scope reporting workflows for MSPs and lean IT teams. Start with sanitized ticket and uptime exports; finish with a completed report, reusable template, QA controls, and a runbook.';
const canonical = new URL('/', Astro.site);
const ogImage = new URL('/og.png', Astro.site);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ZeroBeatLabs',
  alternateName: 'Zero Beat Labs',
  url: 'https://zerobeatlabs.org',
  logo: 'https://zerobeatlabs.org/apple-touch-icon.png',
  description:
    'Human-reviewed IT operations automation. ZeroBeatLabs builds fixed-scope reporting workflows that turn ticket, uptime, project, and change exports into leadership-ready reports.',
  founder: { '@type': 'Person', name: 'Sam Jolley', url: 'https://samjolley.com' },
  knowsAbout: [
    'IT operations reporting',
    'workflow automation',
    'MSP reporting',
    'human-in-the-loop AI',
  ],
  // sameAs: list only live profiles. Add each handle as it is claimed.
  sameAs: [
    'https://github.com/zerobeatlabs',
    'https://huggingface.co/ZeroBeatLabs',
    'https://www.linkedin.com/company/zerobeatlabs',
    'https://www.youtube.com/@zerobeatlabs',
    'https://x.com/zerobeatlabs',
    'https://www.tiktok.com/@zerobeatlabs',
    'https://www.pinterest.com/zerobeatlabs',
    'https://www.facebook.com/zerobeatlabs',
    'https://bsky.app/profile/zerobeatlabs.bsky.social',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#16181d" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="ZeroBeatLabs Writing"
      href="/rss.xml"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ZeroBeatLabs" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap">
        <a class="site-name" href="#home">ZeroBeatLabs</a>
        <nav class="site-nav" aria-label="Main navigation">
          <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#sprint">IT Reporting Sprint</a></li>
            <li><a href="#proof">Proof</a></li>
            <li><a href="#process">Process</a></li>
            <li><a href="#faq">Common questions</a></li>
            <li><a href="/writing/">Writing</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <section id="home" aria-labelledby="hero-heading">
        <div class="wrap">
          <p class="eyebrow">Human-reviewed automation for IT operations</p>
          <h1 id="hero-heading">
            Turn recurring IT exports into a report your stakeholders can use
          </h1>
          <p class="lede">
            ZeroBeatLabs builds fixed-scope reporting workflows for MSPs and
            lean IT teams. Start with sanitized ticket and uptime exports;
            finish with a completed report, reusable template, QA controls,
            and a runbook.
          </p>
          <p>
            <a class="button" href="#contact">Discuss your reporting workflow</a>
          </p>
          <ul class="trust-strip">
            <li>No production credentials required</li>
            <li>Human approval built in</li>
            <li>Fixed inputs and outputs</li>
          </ul>
        </div>
      </section>

      <section aria-labelledby="problem-heading">
        <div class="wrap">
          <h2 id="problem-heading">The data exists. The weekly narrative is still manual.</h2>
          <p>
            Ticketing, monitoring, project, and change systems already contain
            the facts. The reporting burden comes from reconciling those facts
            and rewriting them for clients or leadership. Generic AI summaries
            are not enough when totals need to match and missing data must
            stay visible.
          </p>
        </div>
      </section>

      <section id="sprint" aria-labelledby="offer-heading">
        <div class="wrap">
          <h2 id="offer-heading">AI IT Operations Report Workflow Sprint</h2>
          <p class="price">$1,250 introductory fixed price for the first two engagements</p>
          <h3>Includes</h3>
          <ul class="deliverables">
            <li>up to two sanitized export types</li>
            <li>one completed weekly or monthly report</li>
            <li>reusable report template</li>
            <li>prompt and scoring rubric</li>
            <li>human QA checklist</li>
            <li>written runbook</li>
            <li>45-minute handoff</li>
            <li>one revision</li>
          </ul>
          <h3>Delivery</h3>
          <p>Seven calendar days after complete requirements are received.</p>
          <p>One-time engagement. Fixed scope, no retainer, no lock-in.</p>
        </div>
      </section>

      <section id="process" aria-labelledby="process-heading">
        <div class="wrap">
          <h2 id="process-heading">Process</h2>
          <ol class="process-steps">
            <li>
              <strong>Map</strong>
              Agree on inputs, audience, metrics, and acceptance.
            </li>
            <li>
              <strong>Build</strong>
              Calculate the metrics and draft the report.
            </li>
            <li>
              <strong>Review</strong>
              Reconcile the output and complete human QA.
            </li>
            <li>
              <strong>Handoff</strong>
              Deliver the reusable system and operating guide.
            </li>
          </ol>
        </div>
      </section>

      <section aria-labelledby="boundaries-heading">
        <div class="wrap">
          <h2 id="boundaries-heading">Boundaries</h2>
          <p>
            The sprint does not include production credentials, live
            integrations, automated sending or record changes, dashboards,
            emergency support, regulated decisions, or sensitive data.
          </p>
        </div>
      </section>

      <section id="faq" aria-labelledby="faq-heading">
        <div class="wrap">
          <h2 id="faq-heading">Common questions</h2>
          <h3>Do you need access to our systems?</h3>
          <p>No. You send sample-shaped ticket and uptime exports. No production credentials, no live integrations, no changes to your records.</p>
          <h3>How long does it take?</h3>
          <p>Seven calendar days after complete requirements are received.</p>
          <h3>How do I know the numbers are right?</h3>
          <p>Every material number is recomputed from the source rows and reconciled before delivery, and a named human approves the report. One revision is included.</p>
          <h3>Do I have to sign up for anything ongoing?</h3>
          <p>No. The sprint is fixed-scope and one-time. There is no retainer and no lock-in.</p>
          <h3>Is this just an AI summary of my files?</h3>
          <p>No. Calculation is deterministic, the AI drafts only the narrative, and a human reconciles every figure. You can watch the method run in the live demo before you buy.</p>
        </div>
      </section>

      <section id="proof" aria-labelledby="proof-heading">
        <div class="wrap">
          <h2 id="proof-heading">See the workflow before you buy it</h2>
          <p>
            Review the public sample demonstration. It shows the method
            without exposing a private environment or pretending a sample is
            client work.
          </p>
          <p>The demonstration includes:</p>
          <ul class="deliverables">
            <li>sample sanitized exports (tickets and uptime)</li>
            <li>a completed report</li>
            <li>the quality rubric</li>
            <li>the reconciliation checklist</li>
            <li>the runbook</li>
          </ul>
          <p>
            <a class="button" href="https://demo.zerobeatlabs.org/reconcile">Try the live demo</a>
          </p>
          <p>
            Read the method behind it:
            <a href="/writing/why-summarizing-files-fails-for-it-operations-reports/">Why "just summarize the files" fails for IT operations reports</a>.
          </p>
          <p class="note">All data is sample data, from a made-up organization; no client information.</p>
          <!-- secondary proof repo link: pending public release -->
        </div>
      </section>

      <section id="contact" aria-labelledby="contact-heading">
        <div class="wrap">
          <h2 id="contact-heading">Have a report your team rebuilds every week?</h2>
          <p>
            Bring the current report and two sanitized sample exports. We will
            quickly determine whether the fixed-scope sprint fits.
          </p>
          <p>
            <a class="button" href="mailto:hello@zerobeatlabs.org">hello@zerobeatlabs.org</a>
          </p>
          <p class="note">
            Prefer to talk first? Call <a href="tel:+18102304295">(810) 230-4295</a>
            or <a href="https://calendar.app.google/ZzgzTAhCFCk1oxBH8">book a 10-minute call</a>.
          </p>
          <p class="note">
            The reporting sprint is the flagship of a broader human-reviewed IT
            and AI automation practice. For other fixed-scope IT or AI work, use
            the same address above.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p>
          &copy; {new Date().getFullYear()} ZeroBeatLabs LLC &middot; a service by
          <a href="https://samjolley.com">Sam Jolley</a>
          &middot; <a href="tel:+18102304295">(810) 230-4295</a>
          &middot; <a href="/privacy/">Privacy</a>
        </p>
        <p>
          We also build clean, fast websites for local businesses at
          <a href="https://web.zerobeatlabs.org">web.zerobeatlabs.org</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
