---
import SiteShell from '../layouts/SiteShell.astro';

const title = 'ZeroBeatLabs | Governed workflow automation for IT and operations';
const description =
  'ZeroBeatLabs builds governed AI workflow automation for MSPs, internal IT, professional services, and lean operations teams, with defined authority and human ownership.';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ZeroBeatLabs',
  alternateName: 'Zero Beat Labs',
  url: 'https://zerobeatlabs.org',
  telephone: '+1-810-230-4295',
  email: 'hello@zerobeatlabs.org',
  logo: 'https://zerobeatlabs.org/apple-touch-icon.png',
  description:
    'Governed workflow automation for IT and operations, including controlled agentic workflows and a fixed-scope IT reporting workflow sprint.',
  founder: { '@type': 'Person', name: 'Sam Jolley', url: 'https://samjolley.com' },
  knowsAbout: [
    'workflow automation',
    'AI automation with human approval',
    'IT operations reporting',
    'MSP reporting',
    'human-in-the-loop AI',
    'automation governance',
  ],
  sameAs: [
    'https://github.com/zerobeatlabs',
    'https://huggingface.co/ZeroBeatLabs',
    'https://www.linkedin.com/company/zerobeatlabs',
    'https://www.youtube.com/@zerobeatlabs',
    'https://x.com/zerobeatlabs',
    'https://www.tiktok.com/@zerobeatlabs',
    'https://www.pinterest.com/zerobeatlabs',
    'https://www.facebook.com/zerobeatlabs',
    'https://bsky.app/profile/zerobeatlabs.bsky.social',
    'https://www.instagram.com/getzerobeatlabs',
    'https://substack.com/@zerobeatlabs',
    'https://www.reddit.com/user/zerobeatlabs',
  ],
};
---

<SiteShell
  title={title}
  description={description}
  activePage="home"
  structuredData={orgSchema}
  ogImageAlt="ZeroBeatLabs — governed workflow automation for IT and operations"
>
  <section id="home" class="hero" aria-labelledby="hero-heading">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Governed workflow automation for IT and operations.</p>
        <h1 id="hero-heading">Move recurring work forward without giving AI unchecked authority.</h1>
        <p class="lede">
          ZeroBeatLabs builds controlled workflows for MSPs, internal IT,
          professional services, and lean operations teams. Each workflow uses
          defined inputs, approved tools, validation, and human ownership.
        </p>
        <div class="hero-actions">
          <a class="button" href="/services/agentic-workflows/">Explore Agentic Workflows</a>
          <a class="button button-secondary" href="/services/it-reporting/">See the Reporting Sprint</a>
        </div>
      </div>
      <aside class="hero-side" aria-label="Operating principles">
        <p class="label">Control stays visible</p>
        <p>Named owners. Scoped access. Approval gates. Logged outputs. Manual recovery.</p>
      </aside>
    </div>
  </section>

  <section class="section-soft" aria-labelledby="services-heading">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Two ways to begin</p>
        <h2 id="services-heading">Choose the level of access the work actually needs.</h2>
        <p class="lede">
          The Reporting Sprint works from sanitized exports with no production credentials.
          Governed Agentic Workflows can work inside live systems through client-controlled,
          revocable access and explicit authority boundaries.
        </p>
      </div>

      <div class="service-grid">
        <article class="service-card">
          <p class="label">Flagship service · live systems, human-governed</p>
          <h3>Governed Agentic Workflows</h3>
          <p>
            Start with a scoped Workflow and Governance Blueprint, then move to a
            controlled pilot or custom fixed-scope implementation.
          </p>
          <ul class="plain-list">
            <li>Client-owned, least-privilege access</li>
            <li>Named approvals and explicit pre-authorization</li>
            <li>Exception handling, kill switch, and manual fallback</li>
          </ul>
          <div class="card-actions">
            <a class="button" href="/services/agentic-workflows/">Explore Agentic Workflows</a>
          </div>
        </article>

        <article id="sprint" class="service-card reporting-card">
          <p class="label">Entry service · sanitized exports, no credentials</p>
          <h3>IT Reporting Workflow Sprint</h3>
          <p class="price">$1,250 introductory fixed price for the first two engagements</p>
          <p>
            Turn up to two sanitized export types into a completed report, reusable
            template, QA controls, and a written runbook.
          </p>
          <div class="card-actions">
            <a class="button" href="/services/it-reporting/">See the Reporting Sprint</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section aria-labelledby="fit-heading">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Workflow fit</p>
        <h2 id="fit-heading">Start with the process, not the tool.</h2>
        <p class="lede">
          A strong candidate is recurring, consequential enough to matter, and defined
          well enough that success and failure can both be recognized.
        </p>
      </div>
      <div class="fit-grid">
        <div class="fit-panel">
          <h3>Good fit</h3>
          <ul class="check-list">
            <li>Recurring, material work</li>
            <li>A known owner and review standard</li>
            <li>Stable inputs or systems</li>
            <li>Measurable delays, errors, or dropped handoffs</li>
            <li>Clear consequences and reversibility</li>
          </ul>
        </div>
        <div class="fit-panel anti-fit">
          <h3>Not a fit</h3>
          <ul class="anti-list">
            <li>Undefined processes</li>
            <li>Regulated final decisions</li>
            <li>Uncontrolled customer actions</li>
            <li>No human owner</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="process" class="section-soft" aria-labelledby="process-heading">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">How we work</p>
        <h2 id="process-heading">Map → Bound → Pilot → Prove and hand off.</h2>
      </div>
      <ol class="method-grid">
        <li class="method-step">
          <span class="step-number">01 / Map</span>
          <h3>Define the work</h3>
          <p>Agree on the owner, inputs, decisions, outputs, exceptions, and acceptance standard.</p>
        </li>
        <li class="method-step">
          <span class="step-number">02 / Bound</span>
          <h3>Limit authority</h3>
          <p>Specify tools, permissions, approvals, pre-authorized actions, and the kill switch.</p>
        </li>
        <li class="method-step">
          <span class="step-number">03 / Pilot</span>
          <h3>Test the real edges</h3>
          <p>Run a controlled workflow with validation, error branches, and manual recovery.</p>
        </li>
        <li class="method-step">
          <span class="step-number">04 / Prove + hand off</span>
          <h3>Leave an operable system</h3>
          <p>Evaluate against acceptance tests, document ownership, and hand over the runbook.</p>
        </li>
      </ol>
    </div>
  </section>

  <section id="proof" aria-labelledby="proof-heading">
    <div class="wrap">
      <div class="proof-panel">
        <div>
          <p class="eyebrow">Proof of method</p>
          <h2 id="proof-heading">See the validation and human-review method before you buy it.</h2>
          <p>
            The public reporting demonstration shows deterministic calculation,
            reconciliation, and named human review. It is proof of the method, not
            proof of a deployed agentic client system.
          </p>
          <p>
            The demonstration uses sanitized sample exports from a made-up organization;
            it contains no client information.
          </p>
          <div class="hero-actions">
            <a class="button" href="https://demo.zerobeatlabs.org/reconcile">Try the live reporting demo</a>
            <a class="button button-secondary" href="/services/agentic-workflows/#artifacts">See agentic proof artifacts</a>
          </div>
        </div>
        <div class="proof-metric" aria-label="Demonstration scope">
          <span class="sample-label">Sample data</span>
          <strong>Inputs → recount → narrative → human approval</strong>
          <span>No production system access.</span>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="section-soft" aria-labelledby="faq-heading">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Common questions</p>
        <h2 id="faq-heading">What stays under human control?</h2>
      </div>
      <div class="faq-list">
        <details>
          <summary>What is the difference between the two services?</summary>
          <div>
            <p>
              The IT Reporting Workflow Sprint works from sanitized exports and never
              needs production credentials. Governed Agentic Workflows may use live
              systems through client-owned, scoped, revocable access defined in an
              approved workflow specification.
            </p>
          </div>
        </details>
        <details>
          <summary>Do you need our passwords?</summary>
          <div>
            <p>
              No. Discovery can use sanitized or sample-shaped data. When a live
              implementation needs access, it uses accounts controlled by the client;
              the client grants and can revoke the scoped access. ZeroBeatLabs never
              asks the client to hand over passwords.
            </p>
          </div>
        </details>
        <details>
          <summary>Which actions require approval?</summary>
          <div>
            <p>
              Consequential, customer-facing, financial, destructive, or record-of-truth
              actions require named human approval. Lower-risk actions may be automated
              only when explicitly pre-authorized in the approved workflow specification,
              logged, bounded, and recoverable.
            </p>
          </div>
        </details>
        <details>
          <summary>What happens when the workflow is wrong or a dependency fails?</summary>
          <div>
            <p>
              Every workflow includes input and result validation, exception handling,
              a kill switch, and a documented manual fallback. The human owner remains
              responsible for the process and decides how exceptions move forward.
            </p>
          </div>
        </details>
        <details>
          <summary>Who owns the accounts and operating artifacts?</summary>
          <div>
            <p>
              Live accounts remain controlled by the client. The workflow map,
              permission and approval matrix, acceptance tests, runbook, and handoff
              materials are delivered so the client can operate the bounded workflow.
            </p>
          </div>
        </details>
        <details>
          <summary>What does it cost?</summary>
          <div>
            <p>
              The Reporting Sprint is $1,250 at the introductory fixed price for the
              first two engagements. Agentic work starts with a short workflow mapping call; the
              paid Blueprint and any custom fixed-scope implementation are quoted after
              the workflow is understood.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section aria-labelledby="writing-heading">
    <div class="wrap">
      <p class="eyebrow">Writing</p>
      <h2 id="writing-heading">The method behind the work.</h2>
      <p class="lede">
        Read practical notes on validation, reconciliation, evidence boundaries,
        and human-reviewed automation.
      </p>
      <p><a class="button button-secondary" href="/writing/">Browse the writing</a></p>
    </div>
  </section>

  <section id="contact" class="section-ink" aria-labelledby="contact-heading">
    <div class="wrap">
      <p class="eyebrow">Start with one workflow</p>
      <h2 id="contact-heading">Bring the recurring work your team cannot afford to leave vague.</h2>
      <p class="lede">
        We will identify the owner, the review standard, the access boundary, and
        whether the right next step is the Reporting Sprint or a Workflow and
        Governance Blueprint.
      </p>
      <div class="hero-actions">
        <a class="button" href="https://calendar.app.google/ZzgzTAhCFCk1oxBH8">Book a 10-minute workflow mapping call</a>
        <a class="button button-secondary" href="mailto:hello@zerobeatlabs.org">Email hello@zerobeatlabs.org</a>
      </div>
    </div>
  </section>
</SiteShell>
